# UniPay Gateway local Docker example.
# Copy to .env for local compose usage. Do not commit real secrets.

# Host port exposed by docker-compose.
UNIPAY_GATEWAY_PORT=8080

# Gateway must bind to 0.0.0.0 inside a container.
UNIPAY_GATEWAY_BIND_ADDR=0.0.0.0:8080

# Format: caller_id:api_key,caller_id_2:api_key_2
# Generate long random API keys for non-local environments.
UNIPAY_GATEWAY_API_KEYS=demo-backend:replace-with-long-random-api-key

# Tracing filter used by tracing-subscriber.
RUST_LOG=info,unipay_gateway=debug

# Reserved for future durable storage implementation. Not read by current MVP.
# UNIPAY_DATABASE_URL=postgres://unipay:change-me@postgres:5432/unipay

# Reserved for future live WeChat Pay integration. Not read by current MVP.
# UNIPAY_WECHAT_MERCHANT_ID=
# UNIPAY_WECHAT_APP_ID=
# UNIPAY_WECHAT_PRIVATE_KEY_PATH=/run/secrets/wechat_private_key.pem
# UNIPAY_WECHAT_MERCHANT_SERIAL=
# UNIPAY_WECHAT_API_V3_KEY_FILE=/run/secrets/wechat_api_v3_key
# UNIPAY_WECHAT_PLATFORM_CERT_PATH=/run/secrets/wechat_platform_cert.pem
# UNIPAY_WECHAT_NOTIFY_URL=

# Reserved for future live Alipay integration. Not read by current MVP.
# UNIPAY_ALIPAY_APP_ID=
